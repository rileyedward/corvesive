generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id         Int      @id @default(autoincrement())
  first_name String
  last_name  String
  email      String
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  tokens          tokens?
  paystubs        paystubs[]
  paystub_records paystub_records[]
  expenses        expenses[]
  expense_records expense_records[]
}

model tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int       @unique
  token      String    @unique
  created_at DateTime  @default(now())
  expires_at DateTime?

  user users @relation(fields: [user_id], references: [id])
}

model paystubs {
  id                      Int      @id @default(autoincrement())
  user_id                 Int
  issuer                  String
  amount_in_cents         Int
  recurrence_rate         String
  recurrence_interval_one Int
  recurrence_interval_two Int?
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now()) @updatedAt

  user            users             @relation(fields: [user_id], references: [id])
  paystub_records paystub_records[]
}

model paystub_records {
  id              Int      @id @default(autoincrement())
  user_id         Int
  paystub_id      Int
  pay_date        DateTime
  amount_in_cents Int
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  user    users    @relation(fields: [user_id], references: [id])
  paystub paystubs @relation(fields: [paystub_id], references: [id])
}

model expenses {
  id               Int      @id @default(autoincrement())
  user_id          Int
  issuer           String
  name             String
  due_day_of_month Int
  amount_in_cents  Int
  is_variable      Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt

  user            users             @relation(fields: [user_id], references: [id])
  expense_records expense_records[]
}

model expense_records {
  id              Int      @id @default(autoincrement())
  user_id         Int
  expense_id      Int
  due_date        DateTime
  amount_in_cents Int
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  user    users    @relation(fields: [user_id], references: [id])
  expense expenses @relation(fields: [expense_id], references: [id])
}
