generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id         Int      @id @default(autoincrement())
  first_name String
  last_name  String
  email      String
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token      String    @unique
  created_at DateTime  @default(now())
  expires_at DateTime?
}
